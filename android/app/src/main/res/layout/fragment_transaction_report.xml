<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:gravity="center_vertical"
        android:background="@color/surface">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&#8592;"
            android:textColor="@color/blue"
            android:textSize="20sp"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Transaction Report"
            android:textColor="@color/textPrimary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingHorizontal="8dp" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="32dp">

            <!-- All time header -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ALL TIME"
                android:textColor="@color/textSecondary"
                android:textSize="10sp"
                android:letterSpacing="0.1"
                android:paddingTop="16dp"
                android:paddingBottom="10dp" />

            <!-- Summary cards row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:id="@+id/cardSales"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_tx_item"
                    android:padding="12dp"
                    android:layout_marginEnd="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="&#8593;" android:textColor="@color/green" android:textSize="18sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="SALES" android:textColor="@color/textSecondary" android:textSize="9sp" android:letterSpacing="0.06" android:layout_marginTop="6dp"/>
                    <TextView android:id="@+id/tvAllTimeSales" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/green" android:textSize="15sp" android:textStyle="bold" android:layout_marginTop="2dp" android:text="&#8377;0"/>
                    <TextView android:id="@+id/tvAllTimeSalesCount" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/textSecondary" android:textSize="11sp" android:text="0 txns"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardExpenses"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_tx_item"
                    android:padding="12dp"
                    android:layout_marginHorizontal="3dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="&#8595;" android:textColor="@color/red" android:textSize="18sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="EXPENSES" android:textColor="@color/textSecondary" android:textSize="9sp" android:letterSpacing="0.06" android:layout_marginTop="6dp"/>
                    <TextView android:id="@+id/tvAllTimeExpenses" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/red" android:textSize="15sp" android:textStyle="bold" android:layout_marginTop="2dp" android:text="&#8377;0"/>
                    <TextView android:id="@+id/tvAllTimeExpensesCount" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/textSecondary" android:textSize="11sp" android:text="0 txns"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardPurchases"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_tx_item"
                    android:padding="12dp"
                    android:layout_marginStart="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="&#11044;" android:textColor="@color/blue" android:textSize="16sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="PURCHASES" android:textColor="@color/textSecondary" android:textSize="9sp" android:letterSpacing="0.06" android:layout_marginTop="6dp"/>
                    <TextView android:id="@+id/tvAllTimePurchases" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/blue" android:textSize="15sp" android:textStyle="bold" android:layout_marginTop="2dp" android:text="&#8377;0"/>
                    <TextView android:id="@+id/tvAllTimePurchasesCount" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/textSecondary" android:textSize="11sp" android:text="0 txns"/>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MONTH BY MONTH"
                android:textColor="@color/textSecondary"
                android:textSize="10sp"
                android:letterSpacing="0.1"
                android:paddingBottom="10dp" />

            <TextView
                android:id="@+id/tvEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No transactions yet"
                android:textColor="@color/textSecondary"
                android:textSize="14sp"
                android:gravity="center"
                android:padding="32dp"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMonthly"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
