<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingBottom="32dp">

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_handle" />

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvPartyName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/textPrimary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Record Collection"
                android:textColor="@color/textSecondary"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OUTSTANDING"
                android:textColor="@color/textSecondary"
                android:textSize="9sp"
                android:letterSpacing="0.08" />

            <TextView
                android:id="@+id/tvOutstanding"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/red"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Amount input -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="AMOUNT COLLECTED (₹)"
        android:textColor="@color/textSecondary"
        android:textSize="10sp"
        android:letterSpacing="0.1"
        android:paddingHorizontal="20dp"
        android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/etAmount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="12dp"
        android:hint="0"
        android:textColor="@color/textPrimary"
        android:textColorHint="@color/textSecondary"
        android:textSize="22sp"
        android:textStyle="bold"
        android:inputType="numberDecimal"
        android:background="@drawable/bg_tx_item"
        android:padding="14dp" />

    <!-- Date + Note -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/chipDate"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:gravity="center"
            android:paddingHorizontal="14dp"
            android:textColor="@color/textSecondary"
            android:textSize="13sp"
            android:background="@drawable/bg_tab_inactive"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="10dp" />

        <EditText
            android:id="@+id/etNote"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:hint="Note (optional)"
            android:textColor="@color/textPrimary"
            android:textColorHint="@color/textSecondary"
            android:textSize="13sp"
            android:background="@drawable/bg_tab_inactive"
            android:padding="8dp"
            android:inputType="textCapSentences" />
    </LinearLayout>

    <!-- Allocation preview -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ALLOCATION (oldest first)"
        android:textColor="@color/textSecondary"
        android:textSize="10sp"
        android:letterSpacing="0.08"
        android:paddingHorizontal="20dp"
        android:layout_marginBottom="8dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAllocation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:nestedScrollingEnabled="false"
        android:maxHeight="160dp"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="16dp" />

    <!-- Confirm button -->
    <TextView
        android:id="@+id/btnConfirm"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginHorizontal="16dp"
        android:gravity="center"
        android:text="Confirm Collection"
        android:textColor="@color/background"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="@drawable/gradient_btn_sale"
        android:clickable="true"
        android:focusable="true" />

</LinearLayout>
