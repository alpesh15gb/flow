<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingBottom="32dp">

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_handle" />

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Review Slip"
        android:textColor="@color/textPrimary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:paddingHorizontal="20dp"
        android:layout_marginBottom="16dp" />

    <!-- Slip image -->
    <ImageView
        android:id="@+id/ivSlip"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:scaleType="centerCrop"
        android:layout_marginHorizontal="16dp"
        android:background="@color/surface2"
        android:layout_marginBottom="12dp" />

    <!-- OCR status -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Detected:"
            android:textColor="@color/textSecondary"
            android:textSize="12sp"
            android:layout_marginEnd="8dp" />

        <HorizontalScrollView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/llOcrChips"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />
        </HorizontalScrollView>

        <ProgressBar
            android:id="@+id/progressOcr"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- Party -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="PARTY"
        android:textColor="@color/textSecondary"
        android:textSize="10sp"
        android:letterSpacing="0.1"
        android:paddingHorizontal="20dp"
        android:layout_marginBottom="6dp" />

    <Spinner
        android:id="@+id/spinnerParty"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:paddingHorizontal="20dp"
        android:layout_marginBottom="12dp" />

    <!-- Amount -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="AMOUNT (₹)"
        android:textColor="@color/textSecondary"
        android:textSize="10sp"
        android:letterSpacing="0.1"
        android:paddingHorizontal="20dp"
        android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/etAmount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="12dp"
        android:hint="0"
        android:textColor="@color/textPrimary"
        android:textColorHint="@color/textSecondary"
        android:textSize="22sp"
        android:textStyle="bold"
        android:inputType="numberDecimal"
        android:background="@drawable/bg_tx_item"
        android:padding="14dp" />

    <!-- Date + Note row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="20dp">

        <TextView
            android:id="@+id/chipDate"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:gravity="center"
            android:paddingHorizontal="14dp"
            android:textColor="@color/textSecondary"
            android:textSize="13sp"
            android:background="@drawable/bg_tab_inactive"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="10dp" />

        <EditText
            android:id="@+id/etNote"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:hint="Note (optional)"
            android:textColor="@color/textPrimary"
            android:textColorHint="@color/textSecondary"
            android:textSize="13sp"
            android:background="@drawable/bg_tab_inactive"
            android:padding="8dp"
            android:inputType="textCapSentences" />
    </LinearLayout>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <TextView
            android:id="@+id/btnDiscard"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Discard"
            android:textColor="@color/textSecondary"
            android:textSize="15sp"
            android:background="@drawable/bg_tx_item"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="10dp" />

        <TextView
            android:id="@+id/btnApprove"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Approve →"
            android:textColor="@color/background"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/gradient_btn_purchase"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

</LinearLayout>
